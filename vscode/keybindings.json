[
  {
    "key": "ctrl+alt+v",
    "command": "toggleVim",
    "when": "editorTextFocus",
  },
  {
    "key": "shift+alt+f",
    "command": "editor.action.formatDocument",
    "when": "editorHasDocumentFormattingProvider && !editorReadonly",
  },
  {
    "key": "ctrl+k ctrl+shift+4",
    "command": "editor.fold",
    "when": "editorTextFocus",
  },
  {
    "key": "ctrl+k ctrl+shift+5",
    "command": "editor.unfold",
    "when": "editorTextFocus",
  },
  {
    "key": "ctrl+l",
    "command": "settings.cycle.lineNumbers",
    "when": "editorFocus",
  },
]
