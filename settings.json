{
  // --- General Editor Settings ---
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit",
  },
  "editor.minimap.enabled": false,
  "files.eol": "\n",

  // --- Spell Checker Settings (Global) ---
  // Tells the spell checker which languages to check for globally
  "cSpell.language": "en,fr",

  // 1. Set "*" to false: This disables checking for ALL file types by default.
  // 2. Set "markdown" to true: This explicitly re-enables checking ONLY for Markdown files.
  // This combination ensures the 'ignore' language ID (.gitignore) is left unchecked.
  "cSpell.enabledFileTypes": {
    "*": false,
    "markdown": true,
  },

  // --- Chat/UI Settings ---
  "chat.commandCenter.enabled": false,

  // --- Formatter Settings by Language ---

  // JSON files (with and without comments)
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },

  // JavaScript & TypeScript files
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },

  // HTML & CSS files
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },

  // Shell Script files
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format",
  },

  // Python files
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
  },

  // Jupyter Notebook Python code cells
  "[jupyter]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
  },

  // --- Language-Specific Features ---

  // ESLint validation for JS/TS
  "eslint.validate": ["typescript", "javascript"],

  // Python language server (Pylance)
  "python.languageServer": "Pylance",

  // --- Markdown-Specific Settings ---
  "[markdown]": {
    "editor.wordWrap": "on",
  },
  "cSpell.userWords": ["babélienne", "Ramonville", "Roustang", "S'assoir"],
  "python.defaultInterpreterPath": "/usr/bin/python3",

  // --- Settings Cycler ---
  "settings.cycle": [
    {
      "id": "lineNumbers",
      "values": [
        { "editor.lineNumbers": "on" },
        { "editor.lineNumbers": "off" },
      ],
    },
  ],
  "editor.lineNumbers": "on",
}
