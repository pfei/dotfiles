[init]
    defaultBranch = main

[alias]
    lg = log \
        --graph \
        --decorate \
        --date=short \
        --pretty=format:'%C(yellow)%h %C(blue)%ad %C(reset)%s %C(green)%d'

[core]
    editor = hx

[gpg]
    format = ssh

[gpg "ssh"]
    program = ssh-keygen
    allowedSignersFile = ~/.ssh/allowed_signers

[commit]
    gpgsign = true

[diff "jupyternotebook"]
    command = git-nbdiffdriver diff

[merge "jupyternotebook"]
    driver = git-nbmergedriver merge %O %A %B %L %P
    name = jupyter notebook merge driver

[difftool "nbdime"]
    cmd = git-nbdifftool diff \"$LOCAL\" \"$REMOTE\" \"$BASE\"

[difftool]
    prompt = false

[mergetool "nbdime"]
    cmd = git-nbmergetool merge \"$BASE\" \"$LOCAL\" \"$REMOTE\" \"$MERGED\"

[mergetool]
    prompt = false

[include]
    path = /home/pierre/src/private/git/gitconfig.local
